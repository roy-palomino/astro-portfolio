---

<section id="skills" class="min-h-screen pt-20">
  <Container>
    <div class="py-0">
      <h1 class="text-4xl text-gray-800 mb-8">My skills</h1>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8 gap-y-4">
        <SkillDisplay {...languages} />
        <SkillDisplay {...frameworks} />
        <SkillDisplay {...tools} />
        <SkillDisplay {...responsive} />
      </div>
    </div>
  </Container>
</section>
